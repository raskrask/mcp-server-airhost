# MCP サーバー（MCPサーバーの .env と同じ値を使う）
MCP_PUBLIC_URL=https://airhost-mcp-XXXXXXXXXX.asia-northeast1.run.app
MCP_CLIENT_ID=airhost-mcp
MCP_CLIENT_SECRET=your-mcp-client-secret

# LINE Messaging API
LINE_CHANNEL_TOKEN=your-channel-access-token
LINE_USER_IDS=Uxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyy  # カンマ区切りで複数可

# 対象リスティング（カンマ区切りで複数可）
LISTING_IDS=46349408-127c-4401-ae23-28b10b61ce15

# GCS（MCPサーバーと同じバケット可）
GCS_BUCKET=your-bucket
GCS_NOTIFIER_PREFIX=airhost-notifier/notified/

# オプション
LOOKAHEAD_DAYS=60
LOG_LEVEL=INFO
