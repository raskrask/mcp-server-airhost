# =========================================================================
# Airhost MCP Server — example env. Copy to .env and fill in.
# =========================================================================

# ---- MCP server (HTTP / Bearer auth) ----
# Comma-separated list of accepted bearer tokens. Generate with: openssl rand -hex 32
MCP_BEARER_TOKENS=replace-with-strong-random-token,another-token-for-second-user
# Bind address. On Cloud Run, leave PORT to be injected by the platform.
HOST=0.0.0.0
PORT=8080
# Public-facing path under which MCP is served.
MCP_MOUNT_PATH=/mcp

# ---- Airhost credentials ----
AIRHOST_LOGIN_URL=https://pms.airhost.co/ja/sign_in
AIRHOST_USERNAME=you@example.com
AIRHOST_PASSWORD=your-password
# Use the mock client until the real Playwright flow is implemented.
AIRHOST_CLIENT=mock   # mock | browser
# Headless Chromium (false = visible window, useful for local debugging only)
BROWSER_HEADLESS=true

# ---- MFA strategy ----
# gmail   : poll Gmail API for the MFA email and extract the code
# pubsub  : (future) wait for a Pub/Sub push that delivers the code
# manual  : require the operator to paste the code (dev only)
MFA_STRATEGY=gmail
# Sender / subject pattern to match the MFA email.
# Airhost has two MFA mail flavors:
#   * Normal     subject="[Airhost One] ログインコードは 123456 です。"  (code in subject)
#   * New device subject="新しいデバイスのログイン確認"                  (code in body, e.g. "OTP認証コード: 615436")
# The capture group in MFA_SUBJECT_REGEX extracts the code when present; if
# the matching alternative has no group, the body is searched with
# MFA_CODE_REGEX as fallback.
MFA_SENDER=noreply@airhost.co
MFA_SUBJECT_REGEX=(?:ログインコードは\s+(\d{6})|新しいデバイス|認証コード|OTP)
MFA_CODE_REGEX=\b(\d{6})\b
MFA_TIMEOUT_SECONDS=120

# ---- Gmail (used when MFA_STRATEGY=gmail) ----
# Path to OAuth client secrets json downloaded from GCP console.
GMAIL_CREDENTIALS_PATH=./gmail_credentials.json
# Path where the refresh token gets stored after first-time consent.
GMAIL_TOKEN_PATH=./gmail_token.json

# ---- Pub/Sub (future MFA_STRATEGY=pubsub) ----
PUBSUB_PROJECT_ID=
PUBSUB_SUBSCRIPTION=

# ---- Session store ----
# local : write to SESSION_LOCAL_DIR
# gcs   : write to SESSION_GCS_BUCKET (used on Cloud Run)
SESSION_STORE=local
SESSION_LOCAL_DIR=./.sessions
SESSION_GCS_BUCKET=
SESSION_GCS_PREFIX=airhost-mcp/sessions/
SESSION_TTL_SECONDS=3600

# ---- Logging ----
LOG_LEVEL=INFO
